---
import ThemeToggle from './ThemeToggle.astro';

const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/spec/', label: 'Specification' },
  { href: '/examples/', label: 'Examples' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-mark">Ex</span><span class="logo-text">CSV</span>
    </a>
    <nav>
      {links.map(({ href, label }) => (
        <a href={href} class:list={[{ active: pathname === href || pathname === href.slice(0, -1) }]}>
          {label}
        </a>
      ))}
      <a href="https://github.com/boligolov/excsv" class="gh-link" target="_blank" rel="noopener">GitHub</a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .header-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
  }
  .logo {
    font-size: 1.2rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0;
  }
  .logo:hover { text-decoration: none; }
  .logo-mark {
    background: var(--color-accent);
    color: #fff;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.95rem;
    margin-right: 0.3rem;
  }
  nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    font-size: 0.92rem;
  }
  nav a {
    color: var(--color-muted);
    text-decoration: none;
    font-weight: 500;
  }
  nav a:hover, nav a.active {
    color: var(--color-text);
    text-decoration: none;
  }
  nav a.active {
    color: var(--color-accent);
  }
  .gh-link {
    border: 1px solid var(--color-border);
    padding: 0.3em 0.7em;
    border-radius: 6px;
    font-size: 0.85rem;
  }
  .gh-link:hover {
    border-color: var(--color-muted);
  }
  @media (max-width: 640px) {
    nav { gap: 1rem; font-size: 0.85rem; }
    .gh-link { display: none; }
  }
</style>
