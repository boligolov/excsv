---
interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const raw = await Astro.slots.render('default');

function highlightMeta(html: string): string {
  return html
    .split('\n')
    .map(line => {
      const stripped = line.replace(/^\s*/, '');
      if (stripped.startsWith('#')) {
        return `<span class="hl-meta">${line}</span>`;
      }
      return line;
    })
    .join('\n');
}

const highlighted = highlightMeta(raw);
---

{title && (
  <div class="cb-header">
    <h3>{title}</h3>
    {description && <p>{description}</p>}
  </div>
)}
<pre><code set:html={highlighted} /></pre>

<style>
  .cb-header {
    margin-bottom: 0.5rem;
  }
  .cb-header h3 {
    margin-top: 0;
    margin-bottom: 0.2rem;
    font-size: 1.05rem;
  }
  .cb-header p {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: 0;
  }
  pre :global(.hl-meta) {
    color: var(--color-accent);
  }
</style>
